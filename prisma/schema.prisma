generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String              @id @default(uuid())
  phone              String              @unique
  phoneVerified      Boolean             @default(false)
  fullName           String?
  email              String?             @unique
  emailVerified      Boolean             @default(false)
  avatar             String?             @default("/uploads/avatars/default.png")
  customerId         String              @unique
  providerId         String?             @unique
  roles              String[]            @default(["customer"])
  isProfileComplete  Boolean             @default(false)
  status             String              @default("active")
  isOnline           Boolean             @default(false)
  lastSeen           DateTime?
  blockReason        String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  bookings           Booking[]
  creditOrders       CreditOrder[]
  creditTransactions CreditTransaction[]
  notifications      Notification[]
  providerProfile    ProviderProfile?
  pushTokens         PushToken[]
  refreshTokens      RefreshToken[]
  reviews            Review[]
  addresses          UserAddress[]
  credits            UserCredits?
  recommendations    Recommendation[]
}

model PushToken {
  id        String        @id @default(uuid())
  userId    String
  token     String        @unique
  platform  String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  sessionId String?       @unique
  session   RefreshToken? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionId])
}

model UserCredits {
  id        String   @id @default(uuid())
  userId    String   @unique
  balance   Int      @default(0)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CreditTransaction {
  id          String   @id @default(uuid())
  userId      String
  amount      Int
  type        String
  description String?
  bookingId   String?
  orderId     String?  @unique
  status      String   @default("SUCCESS")
  metadata    Json?
  createdAt   DateTime @default(now())
  booking     Booking? @relation(fields: [bookingId], references: [id])
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([bookingId])
}

model CreditOrder {
  id              String   @id @default(uuid())
  userId          String
  planId          String
  currency        String   @default("INR")
  amount          Float
  status          String   @default("created")
  razorpayOrderId String?  @unique
  paymentId       String?  @unique
  signature       String?
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([razorpayOrderId])
}

model ProviderProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shops     Shop[]
}

model Category {
  id               String        @id @default(uuid())
  name             String        @unique
  icon             String?
  supportsQuantity Boolean       @default(false)
  mascotImage      String?
  startOtpRequired     Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  isVisible        Boolean       @default(true)
  isTrending       Boolean       @default(false)
  order            Int           @default(0)
  subcategories    Subcategory[]
}

model Subcategory {
  id         String   @id @default(uuid())
  name       String
  icon       String?
  categoryId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  isVisible  Boolean  @default(true)
  isTrending Boolean  @default(false)
  order      Int      @default(0)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([name, categoryId])
}

model Shop {
  id                String          @id @default(uuid())
  name              String
  houseNo           String?
  area              String?
  address           String
  experience        String?
  profileImage      String?
  backgroundImages  String[]        @default([])
  gallery           String[]        @default([])
  status            String          @default("PENDING")
  isFrozen          Boolean         @default(false)
  providerProfileId String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  businessSummary   String?
  category          String?
  subcategories     String[]        @default([])
  facilities        String[]        @default([])
  serviceType       String?         @default("in-house")
  tags              String[]        @default([])
  whyChooseUs       String?
  workingDays       String[]        @default(["mon", "tue", "wed", "thu", "fri"])
  workingHoursEnd   String?         @default("06:00 PM")
  workingHoursStart String?         @default("09:00 AM")
  serviceArea       String?
  latitude          Float?
  longitude         Float?
  rejectionReason   String?
  verifiedAt        DateTime?
  communityType     String?         @default("runwal")
  communityId       String?
  averageRating     Float           @default(0)
  reviewCount       Int             @default(0)
  jobsCompleted     Int             @default(0)
  views             Int             @default(0)
  bookings          Booking[]
  reviews           Review[]
  services          Service[]
  slotConfigs       ShopSlotConfig[]
  community         Community?      @relation(fields: [communityId], references: [id])
  providerProfile   ProviderProfile @relation(fields: [providerProfileId], references: [id], onDelete: Cascade)
  recommendations   Recommendation[]
}

model ShopSlotConfig {
  id           String    @id @default(uuid())
  shopId       String
  dayOfWeek    Int?      // 0-6 (0=Sun, 1=Mon, etc.) - null if it's a specific date override
  date         DateTime? // Specific date for override (null for weekly rule)
  startTime    String    // "HH:mm" (e.g., "09:00")
  endTime      String    // "HH:mm" (e.g., "18:00")
  slotDuration Int       @default(60) // minutes
  maxBookings  Int       @default(1)  // concurrency per slot
  isBreak      Boolean   @default(false)
  isActive     Boolean   @default(true) // To enable/disable manually
  label        String?   // e.g., "Lunch", "Personal Time"
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  shop         Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, dayOfWeek])
  @@index([shopId, date])
}

model RefreshToken {
  id         String     @id @default(uuid())
  userId     String
  token      String     @unique
  expiresAt  DateTime
  createdAt  DateTime   @default(now())
  deviceName String?
  platform   String?
  lastActive DateTime   @default(now())
  ipAddress  String?
  pushToken  PushToken?
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Service {
  id             String          @id @default(uuid())
  name           String
  description    String?
  price          Float
  duration       String
  category       String?
  subcategories  String[]        @default([])
  inclusions     String[]        @default([])
  isActive       Boolean         @default(true)
  image          String?
  shopId         String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  isFeatured     Boolean         @default(false)
  averageRating  Float           @default(0)
  reviewCount    Int             @default(0)
  shop           Shop?           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  serviceRatings ServiceRating[]
  bookings       Booking[]       @relation("BookingToService")
  bookingItems   BookingItem[]
}

model Advertisement {
  id           String    @id @default(uuid())
  title        String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  type         String    @default("IMAGE")
  image        String?
  headline     String?
  subText      String?
  badge        String?
  btnLabel     String?   @default("Book Now")
  bgFrom       String?   @default("#FFFFFF")
  accent       String?   @default("#000000")
  sharpCorners Boolean   @default(false)
  showTitle    Boolean   @default(true)
  titleColor   String?   @default("#FFFFFF")
  link         String?
  targetId     String?
  targetType   String?
  endDate      DateTime?
  order        Int       @default(0)
  position     String    @default("HOME_TOP")
  startDate    DateTime?
}

model Booking {
  id                 String              @id @default(uuid())
  displayId          String?             @unique
  userId             String
  shopId             String
  addressId          String?
  addressData        Json?
  scheduledDate      DateTime
  scheduledTime      String
  status             BookingStatus       @default(PENDING)
  potentialProviders String[]            @default([])
  currentProviderIndex Int               @default(0)
  dispatchTimeoutAt  DateTime?
  totalRetries       Int                 @default(0)
  manualRetries      Int                 @default(0)
  otp                String?
  completionOtp      String?
  totalAmount        Float               @default(0)
  creditFeePaid      Boolean             @default(false)
  creditFeeAmount    Int                 @default(0)
  isCallUnlocked     Boolean             @default(false)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  address            UserAddress?        @relation(fields: [addressId], references: [id], onDelete: SetNull)
  shop               Shop                @relation(fields: [shopId], references: [id])
  user               User                @relation(fields: [userId], references: [id])
  items              BookingItem[]
  creditTransactions CreditTransaction[]
  review             Review?
  services           Service[]           @relation("BookingToService")
  chatRoom           ChatRoom?
  calls              Call[]
}

model Call {
  id          String   @id @default(uuid())
  bookingId   String
  callerId    String
  receiverId  String
  channelName String   @unique
  status      String   @default("RINGING") // RINGING, ONGOING, COMPLETED, MISSED, REJECTED
  startTime   DateTime @default(now())
  endTime     DateTime?
  duration    Int?     // seconds
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([callerId])
  @@index([receiverId])
}

model SlotLock {
  id            String   @id @default(uuid())
  shopId        String
  scheduledDate DateTime
  scheduledTime String
  expiresAt     DateTime
  userId        String
  createdAt     DateTime @default(now())

  @@unique([shopId, scheduledDate, scheduledTime])
  @@index([expiresAt])
}

model ChatRoom {
  id        String    @id @default(uuid())
  bookingId String    @unique
  isLocked  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  booking   Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  messages  Message[]
}

model Message {
  id                 String    @id @default(uuid())
  roomId             String
  senderId           String
  content            String
  type               String    @default("TEXT") // TEXT, SYSTEM, CUSTOM_SERVICE
  status             String    @default("SENT") // SENT, DELIVERED, READ
  deliveredAt        DateTime?
  seenAt             DateTime?
  customServiceData  Json?     // { name, price }
  approvalStatus     String?   // PENDING, APPROVED, DECLINED
  createdAt          DateTime  @default(now())
  room               ChatRoom  @relation(fields: [roomId], references: [id], onDelete: Cascade)
}

model BookingItem {
  id        String   @id @default(uuid())
  bookingId String
  serviceId String
  quantity  Int      @default(1)
  price     Float
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  service   Service  @relation(fields: [serviceId], references: [id])
}

model UserAddress {
  id        String    @id @default(uuid())
  userId    String
  label     String
  name      String?   // Receiver/Contact Name
  icon      String    @default("home")
  address   String
  area      String?
  landmark  String?
  latitude  Float?
  longitude Float?
  isDefault Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  bookings  Booking[]
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Community {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  description String?
  svgName     String?
  bgColor     String?  @default("#E8F5E9")
  textColor   String?  @default("#2E7D32")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  shops       Shop[]
}

model CreditPlan {
  id           String    @id @default(uuid())
  credits      Int
  price        Float
  label        String?
  popular      Boolean   @default(false)
  savings      String?
  validityDays Int       @default(365)
  isActive     Boolean   @default(true)
  startDate    DateTime?
  endDate      DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Coupon {
  id             String    @id @default(uuid())
  code           String    @unique
  type           String    @default("PERCENT")
  discount       Float
  minAmount      Float?    @default(0)
  usageLimit     Int?
  usedCount      Int       @default(0)
  isActive       Boolean   @default(true)
  isRedeemable   Boolean   @default(false)
  creditsAwarded Int?
  targetUserId   String?
  startDate      DateTime? @default(now())
  expiryDate     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model GlobalSettings {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  type        String   @default("number")
  label       String?
  description String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

model Review {
  id             String          @id @default(uuid())
  bookingId      String          @unique
  userId         String
  shopId         String
  overallRating  Float
  comment        String?
  tags           String[]        @default([])
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  booking        Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  shop           Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceRatings ServiceRating[]

  @@index([userId])
  @@index([shopId])
}

model ServiceRating {
  id        String   @id @default(uuid())
  reviewId  String
  serviceId String
  rating    Float
  comment   String?
  createdAt DateTime @default(now())
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([reviewId, serviceId])
  @@index([serviceId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String
  type      String   @default("GENERAL")
  isRead    Boolean  @default(false)
  data      Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Recommendation {
  id        String   @id @default(uuid())
  userId    String
  shopId    String
  status    String   // YES, NO, MAYBE
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([userId, shopId])
  @@index([shopId])
}

model SearchLog {
  id          String   @id @default(uuid())
  query       String
  userId      String?
  communityId String?
  createdAt   DateTime @default(now())

  @@index([query])
  @@index([createdAt])
}

model SearchKeyword {
  id        String   @id @default(uuid())
  keyword   String   @unique
  isPinned  Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([keyword])
}

enum Role {
  CUSTOMER
  PROVIDER
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  ARRIVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DECLINED
  EXPIRED
}

