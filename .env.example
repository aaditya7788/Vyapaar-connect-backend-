# Server Config
PORT=5000
NODE_ENV=development

# Database (Supabase / PostgreSQL)
# Replace with your actual connection string from Supabase
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@[YOUR-PROJECT-ID].supabase.co:5432/postgres"

# JWT Config
JWT_SECRET="your-very-long-and-secure-secret-key-change-this"
JWT_EXPIRE=7d
